# Local run from Windows/Git Bash, when PostgreSQL and external service are exposed on localhost
POSTGRES_DB=cadastral_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadastral_db
EXTERNAL_SERVICE_URL=http://localhost:8001/result
EXTERNAL_TIMEOUT_SECONDS=65
EXTERNAL_MAX_DELAY_SECONDS=60
